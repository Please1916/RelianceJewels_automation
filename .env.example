# UAT Database (PostgreSQL) — copy this file to .env and fill in your values.
# .env is gitignored; never commit real credentials.

UAT_DB_HOST=your-uat-db-host.example.com
UAT_DB_PORT=5432
UAT_DB_NAME=your_pricing_db
UAT_DB_USER=readonly_pricing_user
UAT_DB_PASSWORD=your_password_here

# Set to 'true' only if your UAT Postgres requires SSL
UAT_DB_SSL=false
