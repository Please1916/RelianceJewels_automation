{
  "name": "jewels-playwright",
  "version": "1.0.0",
  "description": "Playwright tests for Reliance Jewels",
  "type": "module",
  "scripts": {
    "setup": "npm install && npx playwright install chromium",
    "auth:login": "node scripts/auth-login.mjs",
    "start": "node scripts/portal-server.mjs",
    "test": "playwright test plp clp-p0 search-p0",
    "test:plp": "playwright test plp",
    "test:clp": "playwright test clp-p0",
     "test:pdp": "playwright test pdp-P0,P1",
    "test:search": "playwright test search-p0",
    "test:headed": "playwright test plp clp-p0 search-p0 --headed",
    "test:ui": "playwright test --ui",
    "report": "node scripts/generate-report-pdf.mjs",
    "report:automation": "node scripts/generate-automation-report-pdf.mjs",
    "report:pdp": "node scripts/generate-pdp-report.mjs",
    "report:wishlist": "node scripts/generate-wishlist-report.mjs",
    "report:appointment": "node scripts/generate-book-appointment-report.mjs",
    "test:appointment": "playwright test book-appointment",
    "report:callback": "node scripts/generate-call-back-report.mjs",
    "test:callback": "playwright test call-back",
    "report:contactus": "node scripts/generate-contact-us-report.mjs",
    "test:contactus": "playwright test contact-us",
    "test:sanity": "playwright test sanity",
    "report:sanity": "node scripts/generate-sanity-report.mjs",
    "test:report:sanity": "npm run test:sanity; npm run report:sanity",
    "report:html": "playwright show-report",
    "test:report": "npm run test; npm run report",
    "test:report:pdp": "npm run test:pdp; npm run report:pdp",
    "test:report:appointment": "npm run test:appointment; npm run report:appointment",
    "test:report:callback": "npm run test:callback; npm run report:callback",
    "test:report:contactus": "npm run test:contactus; npm run report:contactus",
    "portal": "node scripts/portal-server.mjs",
    "portal:cli": "node scripts/test-portal.mjs",
    "codegen": "playwright codegen https://reliancejewels.snghostz5.de/",
    "diagram": "node docs/render-diagram.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
