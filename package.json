{
  "name": "jewels-playwright",
  "version": "1.0.0",
  "description": "Playwright tests for Reliance Jewels",
  "type": "module",
  "scripts": {
    "setup": "npm install && npx playwright install chromium",
    "test": "playwright test plp-p0 clp-p0 search-p0",
    "test:plp": "playwright test plp-p0",
    "test:clp": "playwright test clp-p0",
    "test:search": "playwright test search-p0",
    "test:headed": "playwright test plp-p0 clp-p0 search-p0 --headed",
    "test:ui": "playwright test --ui",
    "test:pdp": "playwright test pdp-P0,P1",
    "report": "node scripts/generate-report-pdf.mjs",
    "report:html": "playwright show-report",
    "test:report": "npm run test; npm run report",
    "portal": "node scripts/portal-server.mjs",
    "portal:cli": "node scripts/test-portal.mjs",
    "codegen": "playwright codegen https://reliancejewels.snghostz5.de/",
    "diagram": "node docs/render-diagram.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
