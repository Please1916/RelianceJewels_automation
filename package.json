{
  "name": "jewels-playwright",
  "version": "1.0.0",
  "description": "Playwright tests for Reliance Jewels",
  "type": "module",
  "scripts": {
    "setup": "npm install && npx playwright install chromium",
    "auth:login": "node scripts/auth-login.mjs",
    "start": "node scripts/portal-server.mjs",
    "test": "playwright test plp clp search",
    "test:plp": "playwright test plp",
    "test:clp": "playwright test clp",
    "test:search": "playwright test search",
    "test:ab": "playwright test address-book",
    "test:policies": "playwright test policies",
    "test:nav": "playwright test nav",
    "test:homepage": "playwright test homepage --workers=1",
    "test:headed": "playwright test plp clp search --headed",
    "test:ui": "playwright test --ui",
    "report": "node scripts/generate-report-pdf.mjs",
    "report:automation": "node scripts/generate-automation-report-pdf.mjs",
    "report:html": "playwright show-report",
    "test:report": "npm run test; npm run report",
    "portal": "node scripts/portal-server.mjs",
    "portal:cli": "node scripts/test-portal.mjs",
    "codegen": "playwright codegen https://reliancejewels.snghostz5.de/",
    "diagram": "node docs/render-diagram.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
